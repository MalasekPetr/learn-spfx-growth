      "websiteUrl": "https://www.malachis.eu/",
      "privacyUrl": "https://www.malachis.eu/spfx-privacy-policy/",
      "termsOfUseUrl": "https://www.malachis.eu/spfx-terms-of-use/",
      "mpnId": "5305658"
    },
    "metadata": {
      "shortDescription": {
        "default": "Malach IS - Seedling: OneDrive File Explorer"
